generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ANALYST
  ADMIN
}

enum SnapshotProcessingStatus {
  IN_REVIEW
  PROCESSED
}

model Company {
  id         String         @id @default(cuid())
  name       String         @unique
  description String        @default("")
  economicSector String     @default("")
  classification String     @default("")
  headcount String          @default("")
  revenueUSD String         @default("")
  avgProfitPercent String   @default("")
  hrName String             @default("")
  hrPosition String         @default("")
  hrEmail String            @default("")
  hrPhone String            @default("")
  hrCell String             @default("")
  minVacationDays String    @default("")
  minUtilityDays String     @default("")
  conversionRate String     @default("")
  locality String           @default("")
  users      User[]
  snapshots  UserSnapshot[]
  positions  UserPosition[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model User {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  role         UserRole @default(USER)
  name         String
  email        String   @unique
  passwordHash String
  workspace    UserWorkspace?
  snapshots    UserSnapshot[]
  positions    UserPosition[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UserWorkspace {
  userId             String   @id
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  inflation          Float    @default(5)
  snapshotsJson      String   @default("{}")
  selectedSnapshotId String?
  companyInfoJson    String   @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model UserSnapshot {
  id         String         @id @default(cuid())
  userId     String
  companyId  String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  company    Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  snapshotId String
  label      String
  date       DateTime
  status     SnapshotProcessingStatus @default(IN_REVIEW)
  processedAt DateTime?
  positions  UserPosition[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([userId, snapshotId])
  @@index([companyId, date])
}

model UserPosition {
  id            String   @id @default(cuid())
  userId        String
  companyId     String
  userSnapshotId String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  snapshot      UserSnapshot @relation(fields: [userSnapshotId], references: [id], onDelete: Cascade)
  snapshotId    String
  snapshotLabel String
  snapshotDate  DateTime
  positionId    String
  title         String?
  dataJson      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, snapshotId, positionId])
  @@index([userId, snapshotDate])
  @@index([companyId, snapshotDate])
  @@index([userSnapshotId])
}