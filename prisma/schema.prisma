generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  workspace    UserWorkspace?
  positions    UserPosition[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UserWorkspace {
  userId             String   @id
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  inflation          Float    @default(5)
  snapshotsJson      String   @default("{}")
  selectedSnapshotId String?
  companyInfoJson    String   @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model UserPosition {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshotId    String
  snapshotLabel String
  snapshotDate  DateTime
  positionId    String
  title         String?
  dataJson      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, snapshotId, positionId])
  @@index([userId, snapshotDate])
}